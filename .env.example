# WhatsApp Cloud API
WHATSAPP_PHONE_ID=your_phone_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here
WHATSAPP_TOKEN=your_api_token_here

# Database
DATABASE_URL=postgresql://kisan:kisan@localhost:5432/kisan_ai

# Redis
REDIS_URL=redis://localhost:6379

# FastAPI
FASTAPI_ENV=development
FASTAPI_DEBUG=true
CALLBACK_URL=http://localhost:8000/webhook/whatsapp

# LLM (Grok/Gemini for intent classification)
GROK_API_KEY=optional_for_now
GEMINI_API_KEY=optional_for_now

# Logging
LOG_LEVEL=INFO
